<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ESG 企業永續數據盤查平台</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

@if (User.Identity?.IsAuthenticated == true)
{
    <!-- 導覽列 -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-esg sticky-top shadow-sm">
        <div class="container-fluid">
            <a class="navbar-brand fw-bold" asp-controller="Dashboard" asp-action="Index">
                <i class="bi bi-leaf-fill me-2"></i>ESG 永續盤查平台
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarMain">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")"
                           asp-controller="Dashboard" asp-action="Index">
                            <i class="bi bi-speedometer2 me-1"></i>儀表板
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Upload" ? "active" : "")"
                           asp-controller="Upload" asp-action="Index">
                            <i class="bi bi-cloud-upload me-1"></i>數據上傳
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Export" ? "active" : "")"
                           asp-controller="Export" asp-action="Index">
                            <i class="bi bi-file-earmark-excel me-1"></i>資料匯出
                        </a>
                    </li>
                    @if (User.IsInRole("Admin"))
                    {
                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "ReportSchedule" ? "active" : "")"
                               asp-controller="ReportSchedule" asp-action="Index">
                                <i class="bi bi-calendar-check me-1"></i>排程維護
                            </a>
                        </li>
                    }
                </ul>
                <div class="d-flex align-items-center">
                    <span class="text-white-50 me-3">
                        <i class="bi bi-person-circle me-1"></i>
                        @User.Identity.Name
                        @if (User.IsInRole("Admin"))
                        {
                            <span class="badge bg-warning text-dark ms-1">管理員</span>
                        }
                    </span>
                    <form asp-controller="Account" asp-action="Logout" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-outline-light btn-sm">
                            <i class="bi bi-box-arrow-right me-1"></i>登出
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </nav>
}

<!-- 主要內容 -->
<div class="@(User.Identity?.IsAuthenticated == true ? "container-fluid py-4 px-4" : "")">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mb-3" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show mb-3" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @RenderBody()
</div>

<footer class="footer mt-auto py-3 bg-light border-top">
    <div class="container-fluid text-center text-muted small">
        <i class="bi bi-leaf me-1 text-success"></i>
        ESG 企業永續數據盤查平台 &copy; @DateTime.Now.Year &nbsp;|&nbsp; 依 ISO 14064 / GHG Protocol 規範設計
    </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.2/dist/chart.umd.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
